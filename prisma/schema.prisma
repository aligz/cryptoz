generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Coin {
  id        String   @id @default(uuid())
  symbol    String   @unique
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BotConfig {
  id               String   @id @default("global")
  timeframe        String   @default("5m")
  smaPeriod        Int      @default(20)
  volumeMultiplier Float    @default(3.0)
  isActive         Boolean  @default(false)
  updatedAt        DateTime @updatedAt
  minVolume        Float    @default(10000.0)
  minGreenCandles  Int      @default(0)
}

model BreakoutAlert {
  id              String   @id @default(uuid())
  symbol          String
  timeframe       String
  previousVolume  Float
  currentVolume   Float
  multiplier      Float
  priceAtBreakout Float?
  timestamp       DateTime @default(now())

  @@index([symbol, timestamp])
}
